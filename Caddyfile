# FocusPot Caddyfile — Automatic HTTPS with Let's Encrypt
# Replace focuspot.example.com with your actual domain

focuspot.example.com {
    # Reverse proxy to the Next.js web app
    reverse_proxy web:3000

    # Security headers
    header {
        # HTTPS enforcement
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Prevent clickjacking
        X-Frame-Options "DENY"
        # Prevent MIME-type sniffing
        X-Content-Type-Options "nosniff"
        # XSS protection
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Content Security Policy (adjust as needed)
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none';"
        # Remove Caddy version header
        -Server
    }

    # Gzip compression
    encode gzip zstd

    # Static asset caching
    @static path /_next/static/* /favicon.ico /logo.svg
    handle @static {
        header Cache-Control "public, max-age=31536000, immutable"
        reverse_proxy web:3000
    }

    # API rate limiting (basic)
    @api path /api/*
    handle @api {
        reverse_proxy web:3000
    }

    # Logging
    log {
        output file /data/access.log {
            roll_size 100mb
            roll_keep 10
            roll_keep_for 720h
        }
        format json
    }
}
